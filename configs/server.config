
# Jellybean Inference Runtime Configuration
# This file drives the serving state and performance tunables of the runtime.

# --- Model & Backend Configuration ---
model_id=transformer
model_path=model.pt
device=cpu

# --- Network & Server Settings ---
host=0.0.0.0
port=9000
max_requests=0
log_file=jellybean.log

# --- Validation Contracts ---
# Shape should be comma-separated integers
input_shape=1,128,512
expected_output_elems=65536

# --- Runtime & Scheduler Tunables ---
# Number of dedicated worker threads for model execution
worker_threads=2

# Bounded queue size for backpressure (fixed at 1024 in some implementations)
max_queue_size=1024

# Timeout for client requests when the model queue is full (ms)
enqueue_timeout_ms=5

# --- Dynamic Batching Parameters ---
# Maximum number of requests to group together for a single inference pass
max_batch_size=4

# Maximum time (in microseconds) to wait for a batch to fill before flushing
max_batch_delay_us=1000
